│   ├── 03_clustering_analysis.ipynb
│   └── 04_results_visualization.ipynb
├── data/
│   ├── raw/                  # Downloaded GEE data
│   ├── processed/            # Processed datasets
│   └── results/              # Clustering results
└── tests/
    ├── __init__.py
    ├── test_data_loading.py
    └── test_fire_metrics.py
```

