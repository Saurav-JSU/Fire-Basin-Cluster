│   │   └── preprocessor.py    # Data preprocessing utilities
│   ├── features/
│   │   ├── __init__.py
│   │   ├── fire_metrics.py    # Fire characteristic calculations
│   │   └── temporal_analysis.py  # Temporal pattern analysis
│   ├── clustering/
│   │   ├── __init__.py
│   │   ├── algorithms.py      # Clustering implementations
│   │   └── validation.py      # Cluster validation methods
│   └── visualization/
│       ├── __init__.py
│       ├── maps.py           # Geospatial visualizations
│       └── plots.py          # Statistical plots
├── notebooks/
│   ├── 01_data_exploration.ipynb
